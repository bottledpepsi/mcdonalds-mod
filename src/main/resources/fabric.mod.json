{
	"schemaVersion": 1,
	"id": "mcdonalds",
	"version": "${version}",
	"name": "McDonalds Mod",
	"description": "Adds various items from the McDonalds menu.",
	"authors": [
		"bottledpepsi"
	],
	"contact": {
		"homepage": "https://bottledpepsi.github.io/",
		"sources": "https://github.com/bottledpepsi/mcdonalds-mod"
	},
	"license": "GPL-3.0",
	"icon": "assets/mcdonalds/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"bottled.mcdonalds.McDonaldsMod"
		],
		"client": [
			"bottled.mcdonalds.McDonaldsModClient"
		]
	},
	"mixins": [
		"mcdonalds.mixins.json",
